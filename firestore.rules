rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: parts
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, < 100 chars)
    //   - description: string (required, < 500 chars)
    //   - price: number (required, >= 0)
    //   - currency: string (required, in ['USD', 'GBP', 'EUR'])
    //   - imageUrl: string (required, < 1000000 chars)
    //   - category: string (required, in ['high-roof', 'low-roof', 'general'])
    //   - featured: boolean (optional)
    //   - createdAt: number (required, immutable)
    //
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - fullName: string (required, < 100 chars)
    //   - email: string (required, < 100 chars)
    //   - phone: string (required, < 50 chars)
    //   - address: string (required, < 500 chars)
    //   - notes: string (optional, < 1000 chars)
    //   - items: list (required, < 50 items)
    //   - totalAmount: number (required, >= 0)
    //   - status: string (required, in ['placed', 'sent'])
    //   - createdAt: number (required, immutable)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "durellnji23@gmail.com" && request.auth.token.email_verified == true;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidPart(data) {
      return hasOnlyAllowedFields(['name', 'description', 'price', 'currency', 'imageUrl', 'category', 'featured', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 500 &&
             data.price is number && data.price >= 0 &&
             data.currency in ['USD', 'GBP', 'EUR'] &&
             data.imageUrl is string && data.imageUrl.size() < 1000000 &&
             data.category in ['high-roof', 'low-roof', 'general'] &&
             (!('featured' in data) || data.featured is bool) &&
             data.createdAt is number;
    }

    function isValidOrder(data) {
      return hasOnlyAllowedFields(['fullName', 'email', 'phone', 'address', 'notes', 'items', 'totalAmount', 'status', 'createdAt']) &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 50 &&
             data.address is string && data.address.size() > 0 && data.address.size() < 500 &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 1000)) &&
             data.items is list && data.items.size() > 0 && data.items.size() < 50 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['placed', 'sent'] &&
             data.createdAt is number;
    }

    match /parts/{partId} {
      allow read: if true; // Anyone can read the parts catalog
      allow create: if isAdmin() && isValidPart(request.resource.data);
      allow update: if isAdmin() && isValidPart(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if isValidOrder(request.resource.data); // Anyone can create an order
      allow update: if isAdmin() && isValidOrder(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }
  }
}
